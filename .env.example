# ─────────────────────────────────────────────────────────────────────────────
# ABaaS — miljøvariabler (eksempel). Kopiér til .env.local og udfyld.
#
# INGEN rigtige secrets i repo (.gitignore dækker .env*). Alle nøgler nedenfor
# afventer account-oprettelse — ejerne opretter accounts og giver Mads adgang.
# Indtil da kører hver sub-processor-adapter som STUB, og feature-flagene er OFF.
# Prod-runtime-secrets sættes i Netlify > Environment variables (hosting = Netlify, ADR 0012).
# ─────────────────────────────────────────────────────────────────────────────

# --- Feature-flags (default OFF; sæt =true for at aktivere en konfigureret adapter) ---
FLAG_BOOKING=
FLAG_VIDEO=
FLAG_PAYMENTS=
FLAG_ACCOUNTING=
FLAG_AIFOLLOWUP=
FLAG_TRANSCRIPTION=
FLAG_EMAIL=
FLAG_SMS=
FLAG_ANALYTICS=
# inAppMessaging udelades bevidst — modulet er uafklaret og kan ikke aktiveres via env.

# --- Database (Supabase Postgres) — region eu-north-1 (Stockholm), jf. ADR 0013 ---
DATABASE_URL=
# db-tests mod lokal Postgres-container (docker-compose.test.yml):
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/abaas_test

# --- Supabase Auth (auth-valg = Supabase Auth, ADR 0013) ---
# URL + anon-nøgle er offentlige by design (klient-eksponeret via NEXT_PUBLIC_).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role-nøgle: SERVER-ONLY hemmelighed — ALDRIG NEXT_PUBLIC_. Bruges kun server-side
# til rolle-opslag (bypasser RLS bevidst). Uden alle tre kører auth som stub (kontofri CI).
SUPABASE_SERVICE_ROLE_KEY=

# --- Cal.com (booking) — afventer plan + multi-host-spike (Trin 9) ---
CALCOM_API_KEY=

# --- Cal Video (multi-party video; optagelse ejes af Cal.com) ---
CALVIDEO_API_KEY=

# --- Stripe + MobilePay (betaling ind) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
MOBILEPAY_MERCHANT_ID=

# --- Bogføring ud (e-conomic ELLER Dinero — leverandørvalg uafklaret) ---
ACCOUNTING_API_KEY=

# --- LLM (Anthropic Claude API eller EU-hostet — EU-residens/DPA uafklaret) ---
LLM_API_KEY=

# --- Transskription (dansk/EU-udbyder uafklaret) ---
TRANSCRIPTION_API_KEY=

# --- Resend (transaktionsmails, EU Dublin) ---
RESEND_API_KEY=
RESEND_FROM_ADDRESS=

# --- inMobile (SMS, dansk) ---
INMOBILE_API_KEY=
INMOBILE_SENDER=

# --- PostHog (analytics + fejlovervågning, EU) — fase 0, live-nøgle afventer ---
POSTHOG_KEY=
POSTHOG_HOST=https://eu.posthog.com
